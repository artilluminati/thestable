# App
APP_NAME=Personal Platform
ENVIRONMENT=development
DEBUG=true

# Security
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# Database
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://platform:platform@localhost:5432/platform

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# Notes module (Module 2)
# Relative to where the process runs (backend/ locally, /app in Docker).
VAULT_PATH=./vault
REMINDERS_DIR_NAME=reminders

# Reminder times like "09:00" are interpreted in this timezone.
TIMEZONE=Europe/Sofia

# Telegram bot for reminders. Leave both empty to disable sending -
# the scheduler will just log a warning and skip. To get these:
# 1) talk to @BotFather, /newbot, copy the token it gives you
# 2) send your bot any message, then open
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    and read "chat":{"id": ...} from the response
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
